{
  "name": "@agent-command/control-plane",
  "version": "0.1.0",
  "private": true,
  "description": "Agent Commander Control Plane - REST + WebSocket server",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "db:migrate": "node scripts/db-migrate.js",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "pretest": "pnpm --filter @agent-command/schema build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "cd ../.. && pnpm exec eslint services/control-plane/src"
  },
  "dependencies": {
    "@agent-command/schema": "workspace:*",
    "@deepgram/sdk": "^4.11.3",
    "@fastify/cors": "^11.3.0",
    "@fastify/rate-limit": "^11.1.0",
    "@fastify/websocket": "^11.3.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "fastify": "^5.10.0",
    "jose": "^5.10.0",
    "openai": "^6.48.0",
    "pg": "^8.22.0",
    "pino-pretty": "^10.3.1",
    "prom-client": "^15.1.3",
    "ulid": "^2.4.0",
    "web-push": "^3.6.7",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^24.13.3",
    "@types/pg": "^8.20.0",
    "@types/web-push": "^3.6.4",
    "@types/ws": "^8.18.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10",
    "ws": "^8.21.1"
  }
}
