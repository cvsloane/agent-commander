# =============================================================================
# CONTROL PLANE CONFIGURATION
# =============================================================================
# Copy to services/control-plane/.env

# -----------------------------------------------------------------------------
# DATABASE
# -----------------------------------------------------------------------------
DATABASE_URL=<postgresql-connection-string>

# -----------------------------------------------------------------------------
# SERVER
# -----------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8080

# Optional: protect `GET /metrics` with a bearer token.
# If set, provide either:
# - `Authorization: Bearer <token>`
# - `x-metrics-token: <token>`
METRICS_TOKEN=

# -----------------------------------------------------------------------------
# SECURITY
# -----------------------------------------------------------------------------
# Must match dashboard CONTROL_PLANE_JWT_SECRET
JWT_SECRET=replace-with-strong-secret

# Public dashboard origin. When set, CORS and browser WebSocket Origins are
# restricted to this origin. Production should always set it.
APP_BASE_URL=https://agent-command.example.com

# Global API rate limit. Health checks and WebSocket upgrades are exempt.
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW_MS=60000

# Optional comma-separated additional browser WebSocket origins.
WS_ALLOWED_ORIGINS=

# One-time browser WebSocket ticket lifetime (maximum 300 seconds).
WS_TICKET_TTL_SECONDS=30

# -----------------------------------------------------------------------------
# OPTIONAL: TAILSCALE
# -----------------------------------------------------------------------------
TAILNET_DOMAIN=tailnet-xyz.ts.net

# -----------------------------------------------------------------------------
# OPTIONAL: WEB PUSH
# -----------------------------------------------------------------------------
# Generate once with: pnpm exec web-push generate-vapid-keys
# All three values are required to enable browser push delivery.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com
