# =============================================================================
# CONTROL PLANE CONFIGURATION
# =============================================================================
# Copy to services/control-plane/.env

# -----------------------------------------------------------------------------
# DATABASE
# -----------------------------------------------------------------------------
DATABASE_URL=<postgresql-connection-string>

# -----------------------------------------------------------------------------
# SERVER
# -----------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8080

# Optional: protect `GET /metrics` with a bearer token.
# If set, provide either:
# - `Authorization: Bearer <token>`
# - `x-metrics-token: <token>`
METRICS_TOKEN=

# -----------------------------------------------------------------------------
# SECURITY
# -----------------------------------------------------------------------------
# Must match dashboard CONTROL_PLANE_JWT_SECRET
JWT_SECRET=replace-with-strong-secret

# -----------------------------------------------------------------------------
# OPTIONAL: TAILSCALE
# -----------------------------------------------------------------------------
TAILNET_DOMAIN=tailnet-xyz.ts.net
