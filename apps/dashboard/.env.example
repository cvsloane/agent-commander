# =============================================================================
# DASHBOARD CONFIGURATION
# =============================================================================
# Copy to apps/dashboard/.env

# -----------------------------------------------------------------------------
# NEXTAUTH
# -----------------------------------------------------------------------------
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-strong-secret

# -----------------------------------------------------------------------------
# GITHUB OAUTH (optional)
# -----------------------------------------------------------------------------
GITHUB_CLIENT_ID=your-client-id
GITHUB_CLIENT_SECRET=your-client-secret

# -----------------------------------------------------------------------------
# CONTROL PLANE
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CONTROL_PLANE_URL=http://localhost:8080
NEXT_PUBLIC_CONTROL_PLANE_WS_URL=ws://localhost:8080/v1/ui/stream
CONTROL_PLANE_JWT_SECRET=replace-with-strong-secret

# -----------------------------------------------------------------------------
# OPTIONAL ACCESS CONTROL
# -----------------------------------------------------------------------------
# Password-based login (used when GitHub OAuth is not configured)
ACCESS_SECRET=replace-with-strong-password

# Per-source failed access-code attempts allowed during the window.
ACCESS_CODE_MAX_ATTEMPTS=5
ACCESS_CODE_WINDOW_SECONDS=300

# OAuth is refused when ALLOWED_EMAILS is empty. Keep the owner in both lists
# to retain admin/operator controls in a single-owner deployment.
ADMIN_EMAILS=you@example.com
ALLOWED_EMAILS=you@example.com
