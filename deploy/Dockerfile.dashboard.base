# Dashboard Dockerfile
FROM node:22-alpine AS base

# Install pnpm
RUN corepack enable && corepack prepare pnpm@9.15.0 --activate

FROM base AS builder

WORKDIR /app

# Copy workspace files
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml* ./
COPY patches/ ./patches/
COPY packages/ac-schema/package.json ./packages/ac-schema/
COPY apps/dashboard/package.json ./apps/dashboard/
COPY tools/eslint-typescript-compat/ ./tools/eslint-typescript-compat/

# Install dependencies
RUN pnpm install --frozen-lockfile

# Copy source files
COPY tsconfig.base.json ./
COPY packages/ac-schema/ ./packages/ac-schema/
COPY apps/dashboard/ ./apps/dashboard/

# Build
RUN pnpm --filter @agent-command/schema build
RUN pnpm --filter @agent-command/dashboard build

# Resolve the Android APK. It is no longer tracked in git (2.3MB per release
# permanently in history); it lives on GitHub Releases instead.
#
#   APK_SOURCE=context  (default) use android-distribution/ from the build
#                       context if it holds an APK, otherwise ship none
#   APK_SOURCE=release  download the asset from a GitHub release
#
# A missing APK is not a build failure: /api/downloads/android-apk already
# returns 404 "APK not available", and the Settings page hides the button.
# Production images should build with APK_SOURCE=release.
FROM alpine:3.22 AS apk-dist

ARG APK_SOURCE=context
ARG APK_RELEASE_TAG=latest
ARG GITHUB_REPOSITORY=cvsloane/agent-commander

WORKDIR /dist
COPY android-distribution/ ./context/

RUN --mount=type=secret,id=github_token \
    set -eu; \
    mkdir -p /dist/out; \
    if [ "$APK_SOURCE" = "release" ]; then \
      apk add --no-cache curl jq >/dev/null; \
      token=""; \
      if [ -f /run/secrets/github_token ]; then token="$(cat /run/secrets/github_token)"; fi; \
      if [ "$APK_RELEASE_TAG" = "latest" ]; then \
        api="https://api.github.com/repos/${GITHUB_REPOSITORY}/releases/latest"; \
      else \
        api="https://api.github.com/repos/${GITHUB_REPOSITORY}/releases/tags/${APK_RELEASE_TAG}"; \
      fi; \
      url="$(curl -fsSL ${token:+-H "Authorization: Bearer $token"} "$api" \
             | jq -r '.assets[]? | select(.name=="agent-command-android.apk") | .url')"; \
      if [ -n "$url" ] && [ "$url" != "null" ]; then \
        curl -fsSL ${token:+-H "Authorization: Bearer $token"} \
             -H 'Accept: application/octet-stream' \
             -o /dist/out/agent-command-android.apk "$url"; \
        echo "Fetched APK from release ${APK_RELEASE_TAG}"; \
      else \
        echo "WARNING: no APK asset on release ${APK_RELEASE_TAG}; image will ship without it"; \
      fi; \
    else \
      cp /dist/context/*.apk /dist/out/ 2>/dev/null \
        && echo "Using APK from build context" \
        || echo "No APK in build context; image will ship without it"; \
    fi

FROM base AS runner

WORKDIR /app

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1

# Create non-root user
RUN addgroup --system --gid 1001 nodejs
RUN adduser --system --uid 1001 nextjs

# Copy built files
COPY --from=builder /app/apps/dashboard/public ./apps/dashboard/public
COPY --from=builder --chown=nextjs:nodejs /app/apps/dashboard/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/apps/dashboard/.next/static ./apps/dashboard/.next/static
COPY --from=apk-dist --chown=nextjs:nodejs /dist/out ./android-distribution

USER nextjs

EXPOSE 3000

ENV PORT=3000
ENV HOSTNAME=0.0.0.0

CMD ["node", "apps/dashboard/server.js"]
