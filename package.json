{
  "name": "agent-command",
  "version": "0.1.0",
  "private": true,
  "description": "Agent Commander - Mission control dashboard for AI agent sessions",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "test:ci": "turbo test",
    "test:smoke:dashboard": "playwright test -c playwright.dashboard.config.ts",
    "test:journeys": "playwright test -c playwright.journeys.config.ts",
    "verify:launch": "pnpm --filter @agent-command/schema test && pnpm --filter @agent-command/control-plane test && pnpm --filter @agent-command/control-plane typecheck && pnpm --filter @agent-command/dashboard typecheck && pnpm test:smoke:dashboard",
    "lint": "turbo lint",
    "db:migrate": "pnpm --filter @agent-command/control-plane db:migrate",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "@agent-command/eslint-typescript-compat": "file:tools/eslint-typescript-compat",
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "16.2.10",
    "@playwright/test": "^1.61.1",
    "@types/node": "^24.13.3",
    "eslint": "^10.7.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "turbo": "^2.10.5",
    "typescript": "^7.0.2",
    "vite": "8.1.5",
    "vitest": "^4.1.10"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "overrides": {
      "postcss": "8.5.20",
      "vite": "8.1.5"
    },
    "patchedDependencies": {
      "@xterm/xterm@6.0.0": "patches/@xterm__xterm@6.0.0.patch"
    }
  }
}
