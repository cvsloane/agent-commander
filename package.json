{
  "name": "agent-command",
  "version": "0.1.0",
  "private": true,
  "description": "Agent Commander - Mission control dashboard for AI agent sessions",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "test:ci": "turbo test",
    "test:smoke:dashboard": "playwright test -c playwright.dashboard.config.ts",
    "verify:launch": "pnpm --filter @agent-command/schema test && pnpm --filter @agent-command/control-plane test && pnpm --filter @agent-command/control-plane typecheck && pnpm --filter @agent-command/dashboard typecheck && pnpm test:smoke:dashboard",
    "lint": "turbo lint",
    "db:migrate": "pnpm --filter @agent-command/control-plane db:migrate",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^20.19.43",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "eslint": "^9.39.5",
    "eslint-config-next": "16.2.10",
    "prettier": "^3.9.5",
    "turbo": "^2.10.5",
    "typescript": "^5.9.3",
    "vite": "8.1.5",
    "vitest": "^4.1.10"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "overrides": {
      "@babel/core": "7.29.7",
      "eslint-plugin-react-hooks": "7.0.1",
      "postcss": "8.5.20",
      "vite": "8.1.5"
    }
  }
}
